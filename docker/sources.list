# Ubuntu 20.04 (focal) 内网 apt 源（示例为华为云 his-mirrors；其他环境请整文件替换为运维提供的地址）
# 说明：官方写法为 focal-updates（带字母 s），不是 focal-update

deb http://his-mirrors.huawei.com/ubuntu focal main restricted
deb http://his-mirrors.huawei.com/ubuntu focal-updates main restricted
deb http://his-mirrors.huawei.com/ubuntu focal universe
deb http://his-mirrors.huawei.com/ubuntu focal-updates universe
deb http://his-mirrors.huawei.com/ubuntu focal multiverse
deb http://his-mirrors.huawei.com/ubuntu focal-updates multiverse
deb http://his-mirrors.huawei.com/ubuntu focal-backports main restricted universe multiverse
deb http://his-mirrors.huawei.com/ubuntu focal-security main restricted
deb http://his-mirrors.huawei.com/ubuntu focal-security universe
deb http://his-mirrors.huawei.com/ubuntu focal-security multiverse
