# 数据库连接（MySQL 5.7，异步驱动 aiomysql）
DATABASE_URL=mysql+aiomysql://root:root@127.0.0.1:3306/dt_infra?charset=utf8mb4

# JWT 密钥（生产环境请使用高强度随机字符串）
SECRET_KEY=change-me-in-production

# JWT token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 管理员工号列表（逗号分隔，如 ["W00001","W00002"]）
ADMIN_EMPLOYEE_IDS=[]

# MVP 阶段统一登录密码（后续对接域账号认证时移除）
MVP_LOGIN_PASSWORD=dt_report_2026

# CORS 允许源（逗号分隔，如 ["http://localhost:3000"]）
CORS_ORIGINS=["*"]

# WeLink 通知 API 配置
WELINK_API_URL=
WELINK_APP_ID=
WELINK_APP_SECRET=

# WeLink 卡片（黄区会话登录 + 发卡片）：指向部署时提供的 INI 绝对路径，模板见 config/welink_card.ini.example
WELINK_CARD_INI_PATH=

# 对外访问根地址（无尾部 /），一键通知卡片内链接依赖，示例：https://report.example.com
PUBLIC_APP_URL=

# LDAP 域登录（LDAP_HOST 非空时启用域账号登录，留空则使用 MVP 工号+统一密码模式）
LDAP_HOST=
LDAP_PORT=389
LDAP_DOMAIN=

# 日志配置（空则使用默认值）
# ENV: development / production
# LOG_LEVEL: DEBUG / INFO / WARNING / ERROR（空则随 ENV）
# LOG_DIR: 日志目录（空则项目根目录）
ENV=development
LOG_LEVEL=
LOG_DIR=
LOG_APP_MAX_BYTES=10485760
LOG_APP_BACKUP_COUNT=5
LOG_ACCESS_MAX_BYTES=10485760
LOG_ACCESS_BACKUP_COUNT=3
# LOG_SQL: 为 true 时在 app.log 中打印所有 SQL（调试用，生产环境建议关闭）
LOG_SQL=false

# 数据库表结构一致性校验（启动时校验 DDL 与数据库是否一致）
DB_SCHEMA_CHECK_ENABLED=true
DB_SCHEMA_CHECK_FAIL_FAST=true

# AI 失败分析（AIFA）：main_module→仓库 YAML 绝对路径，空则 repo_hint 为空（模板见 config/module_repo_mapping.yaml.example）
AI_MODULE_REPO_MAPPING_PATH=
