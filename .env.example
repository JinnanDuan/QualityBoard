# 数据库连接（MySQL 5.7，异步驱动 aiomysql）
DATABASE_URL=mysql+aiomysql://root:root@127.0.0.1:3306/dt_infra?charset=utf8mb4

# JWT 密钥（生产环境请使用高强度随机字符串）
SECRET_KEY=change-me-in-production

# JWT token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 管理员工号列表（逗号分隔，如 ["W00001","W00002"]）
ADMIN_EMPLOYEE_IDS=[]

# MVP 阶段统一登录密码（后续对接域账号认证时移除）
MVP_LOGIN_PASSWORD=dt_report_2026

# CORS 允许源（逗号分隔，如 ["http://localhost:3000"]）
CORS_ORIGINS=["*"]

# WeLink 通知 API 配置
WELINK_API_URL=
WELINK_APP_ID=
WELINK_APP_SECRET=

# 日志配置（空则使用默认值）
# ENV: development / production
# LOG_LEVEL: DEBUG / INFO / WARNING / ERROR（空则随 ENV）
# LOG_DIR: 日志目录（空则项目根目录）
ENV=development
LOG_LEVEL=
LOG_DIR=
LOG_APP_MAX_BYTES=10485760
LOG_APP_BACKUP_COUNT=5
LOG_ACCESS_MAX_BYTES=10485760
LOG_ACCESS_BACKUP_COUNT=3
# LOG_SQL: 为 true 时在 app.log 中打印所有 SQL（调试用，生产环境建议关闭）
LOG_SQL=false
